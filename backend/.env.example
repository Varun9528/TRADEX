# ── SERVER ──
PORT=5000
NODE_ENV=development

# ── DATABASE ──
MONGODB_URI=mongodb://localhost:27017/tradex_india
# For MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/tradex_india

# ── JWT ──
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here
JWT_REFRESH_SECRET=your_refresh_secret_key_here
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# ── FILE UPLOADS ──
# File uploads are stored locally in /uploads folder
# No external service required

# ── EMAIL (Nodemailer) ──
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=TradeX India <noreply@tradex.in>

# ── FRONTEND URL (CORS) ──
FRONTEND_URL=http://localhost:3000

# ── ADMIN ──
ADMIN_EMAIL=admin@tradex.in
ADMIN_PASSWORD=Admin@123456
